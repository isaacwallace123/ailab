# The Compose stack refuses to start in production mode without this token.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(48))"
AILAB_API_TOKEN=replace-with-a-long-random-token
AILAB_POSTGRES_PASSWORD=replace-with-a-separate-long-random-password
AILAB_API_PORT=8088

# Optional host paths used by Docker Compose. Relative defaults point at sibling repos.
HOMELAB_REPO_PATH=../homelab
CYBERLAB_REPO_PATH=../cyberlab

# Optional read-only live homelab source. Prefer internal TLS with the homelab CA when available.
AILAB_PROMETHEUS_URL=
AILAB_PROMETHEUS_SNAPSHOT_PATH=
AILAB_PROMETHEUS_SNAPSHOT_MAX_AGE_SECONDS=120
AILAB_PROMETHEUS_VERIFY_TLS=true
AILAB_PROMETHEUS_TIMEOUT_SECONDS=5

# Optional host-collected, read-only Kubernetes and ArgoCD status snapshot.
AILAB_KUBERNETES_SNAPSHOT_PATH=
AILAB_KUBERNETES_SNAPSHOT_MAX_AGE_SECONDS=120

# Host-only Proxmox collector credentials. Compose does not pass the token into the service.
AILAB_PROXMOX_ENDPOINT=https://proxmox.example.internal:8006
AILAB_PROXMOX_NODE=cyberlab
AILAB_PROXMOX_API_TOKEN=ailab-status@pve!collector=replace-with-token-secret
AILAB_PROXMOX_VERIFY_TLS=true
AILAB_PROXMOX_SNAPSHOT_PATH=/runtime/cyberlab-proxmox.json
AILAB_PROXMOX_SNAPSHOT_MAX_AGE_SECONDS=300

# Model synthesis uses a dedicated LiteLLM identity. Do not copy its key into this file;
# scripts/start-ai-station.ps1 reads it from the controller-only WSL secret store.
AILAB_LITELLM_API_BASE=http://host.docker.internal:14000/v1
AILAB_ASSISTANT_MODEL=local-auto
AILAB_ASSISTANT_TIMEOUT_SECONDS=210
AILAB_ASSISTANT_KNOWLEDGE_LIMIT=5
AILAB_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
AILAB_EMBEDDING_DIMENSIONS=384
AILAB_EMBEDDING_THREADS=4

# Separate mutation identity used only by the plan wrapper; never use the status token here.
AILAB_TERRAFORM_PROXMOX_API_TOKEN=terraform-ailab@pve!terraform=replace-with-token-secret
AILAB_SSH_PUBLIC_KEY_PATH=C:\Users\replace-me\.ssh\id_ed25519.pub
