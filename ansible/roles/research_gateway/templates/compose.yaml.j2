name: ailab-research

services:
  gateway:
    build:
      context: ./source
    image: localhost/ailab-research-gateway:{{ ailab_research_gateway_version }}
    env_file:
      - ./gateway.env
    ports:
      - "127.0.0.1:{{ ailab_research_gateway_port }}:8000"
    networks:
      - default
      - extraction
      - search
    read_only: true
    tmpfs:
      - /tmp:size=64m,mode=1777
    mem_limit: 512m
    cpus: "1.0"
    pids_limit: 128
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    restart: unless-stopped

networks:
  extraction:
    external: true
    name: ailab-extraction_default
  search:
    external: true
    name: ailab-search_default
