ENV=prod
DATA_DIR={{ ailab_openwebui_state_dir }}/data
WEBUI_URL={{ ailab_openwebui_public_url }}
WEBUI_SECRET_KEY={{ ailab_openwebui_secret_key }}
WEBUI_NAME=AI Lab
WEBUI_ADMIN_EMAIL={{ ailab_openwebui_admin_email }}
WEBUI_ADMIN_PASSWORD={{ ailab_openwebui_admin_password }}
WEBUI_ADMIN_NAME=Isaac
ENABLE_SIGNUP=false
ENABLE_LOGIN_FORM=true
ENABLE_PASSWORD_AUTH=true
ENABLE_PERSISTENT_CONFIG=false
ENABLE_VERSION_UPDATE_CHECK=false
ENABLE_COMMUNITY_SHARING=false
ENABLE_DIRECT_CONNECTIONS=false
ENABLE_API_KEYS=false
ENABLE_OPENAI_API_PASSTHROUGH=false
ENABLE_OLLAMA_API=false
ENABLE_OPENAI_API=true
ENABLE_FORWARD_USER_INFO_HEADERS=true
ENABLE_WEB_SEARCH=true
USER_PERMISSIONS_FEATURES_WEB_SEARCH=true
WEB_SEARCH_ENGINE={{ ailab_openwebui_web_search_engine }}
SEARXNG_QUERY_URL={{ ailab_openwebui_searxng_query_url }}
WEB_SEARCH_RESULT_COUNT={{ ailab_openwebui_web_search_result_count }}
WEB_SEARCH_CONCURRENT_REQUESTS={{ ailab_openwebui_web_search_concurrent_requests }}
WEB_LOADER_CONCURRENT_REQUESTS={{ ailab_openwebui_web_loader_concurrent_requests }}
WEB_FETCH_MAX_CONTENT_LENGTH={{ ailab_openwebui_web_fetch_max_content_length }}
WEB_FETCH_FILTER_LIST={{ ailab_openwebui_web_fetch_filter_list }}
USER_PERMISSIONS_CHAT_MULTIPLE_MODELS=true
ENABLE_EVALUATION_ARENA_MODELS=true
ENABLE_MESSAGE_RATING=true
OPENAI_API_BASE_URLS=http://127.0.0.1:{{ ailab_litellm_port }}/v1;http://127.0.0.1:{{ ailab_openwebui_assistant_port }}/v1
OPENAI_API_KEYS={{ ailab_openwebui_litellm_key }};{{ ailab_openwebui_assistant_api_key }}
OPENAI_API_CONFIGS={"1":{"enable":true,"model_ids":["ailab-assistant","ailab-grounded"],"tags":["assistant","grounded","local"]}}
DATABASE_URL=postgresql://openwebui:{{ ailab_openwebui_database_password }}@127.0.0.1:5432/openwebui
DATABASE_USER_ACTIVE_STATUS_UPDATE_INTERVAL=300
CORS_ALLOW_ORIGIN={{ ailab_openwebui_public_url }}
ENABLE_WEBSOCKET_SUPPORT=true
IFRAME_CSP="default-src 'self' 'unsafe-inline' 'unsafe-eval' data: blob:; connect-src 'none'"
