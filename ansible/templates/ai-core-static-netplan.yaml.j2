network:
  version: 2
  ethernets:
    eth0:
      match:
        macaddress: "{{ ailab_core_mac_address }}"
      set-name: eth0
      dhcp4: false
      addresses:
        - "{{ ailab_core_ipv4_address }}/{{ ailab_core_ipv4_prefix }}"
      routes:
        - to: default
          via: "{{ ailab_core_ipv4_gateway }}"
      nameservers:
        addresses: {{ ailab_core_dns_servers | to_json }}

